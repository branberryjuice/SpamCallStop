# Copy this file to .env and fill in real values. Never commit .env.

# Server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Stripe — start with TEST keys (sk_test_..., whsec_...), swap to live at launch
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Database — Render Postgres connection string (added at the database step)
DATABASE_URL=

# Twilio Verify — phone OTP (no A2P 10DLC needed for Verify)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
VERIFY_DAILY_CAP=500

# Secret used to sign short-lived "phone verified" tokens (set a long random value)
APP_SECRET=

# Resend — transactional + removal-request email (domain must be verified)
RESEND_API_KEY=
EMAIL_FROM=removals@spamcallstop.com
