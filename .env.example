# Copy this file to .env and fill in real values. Never commit .env.

# Server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Stripe — start with TEST keys (sk_test_..., whsec_...), swap to live at launch
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Database — Render Postgres connection string (added at the database step)
DATABASE_URL=

# Twilio Verify — phone OTP (no A2P 10DLC needed for Verify).
# The same Account SID + Auth Token also power Lookup (name via caller_name,
# name+address via pre_fill — request pre_fill access in the Twilio console).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
VERIFY_DAILY_CAP=500

# Trestle Reverse Phone API — real-time phone -> owner name + current address +
# age range (no DOB). ~$0.07/query, pay-as-you-go. Get a key at trestleiq.com.
TRESTLE_API_KEY=

# Secret used to sign short-lived "phone verified" tokens (set a long random value)
APP_SECRET=

# Admin dashboard key — gates /api/admin/* (dashboard.html). Set a long random
# value; if unset, the admin API stays locked.
ADMIN_KEY=

# Resend — transactional + removal-request email (domain must be verified)
RESEND_API_KEY=
EMAIL_FROM=removals@spamcallstop.com
